<?php get_header(); ?>

<?php
/* If the admin has set a static "Front page" in Settings → Reading AND that
 * page contains block-editor content, render its blocks (so admins can fully
 * compose the home with patterns). Otherwise — and this is the default —
 * render the full Infer Nepal home layout below. */
$static_id = (int) get_option('page_on_front');
if ($static_id && has_blocks(get_post_field('post_content', $static_id))) :
    echo '<div class="page-content">';
    echo apply_filters('the_content', get_post_field('post_content', $static_id));
    echo '</div>';
else : ?>

<!-- Hero -->
<section class="hero">
  <div class="container">
    <div class="eyebrow"><span class="dot"></span>
      <?php
      $sw_count   = (int) wp_count_posts('software')->publish;
      $rev_total  = 0;
      $rq = new WP_Query(['post_type' => 'software', 'posts_per_page' => -1, 'fields' => 'ids']);
      foreach ($rq->posts as $pid) $rev_total += (int) get_post_meta($pid, 'review_count', true);
      wp_reset_postdata();
      printf('%d software · %s+ verified reviews · updated weekly', $sw_count, number_format($rev_total));
      ?>
    </div>
    <h1>Find the right software <em>for every Nepali business.</em></h1>
    <p class="lede">Independent reviews, transparent pricing and side-by-side comparison for ERP, accounting, school, hotel, hospital and HR software — built for buyers in 🇳🇵 Nepal.</p>
    <form role="search" method="get" action="<?= esc_url(home_url('/')) ?>" class="hero-search">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="color:var(--text-subtle)"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
      <input name="s" placeholder="Try Tally vs Swastik, school ERP, hospital HMS…" />
      <input type="hidden" name="post_type" value="software" />
      <button class="btn primary" type="submit">Search</button>
    </form>
    <div class="hero-trending">
      <span>Popular:</span>
      <?php
      $hot = new WP_Query(['post_type'=>'software','posts_per_page'=>5,'meta_key'=>'review_count','orderby'=>'meta_value_num','order'=>'DESC','fields'=>'ids']);
      foreach ($hot->posts as $pid) {
          printf('<a href="%s" class="chip">%s</a> ', esc_url(get_permalink($pid)), esc_html(get_the_title($pid)));
      }
      wp_reset_postdata();
      ?>
    </div>
  </div>
</section>

