{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "color": {
      "palette": [
        { "slug": "brand",         "name": "Infer Blue",     "color": "#0A7AA9" },
        { "slug": "brand-deep",    "name": "Infer Blue Deep","color": "#066189" },
        { "slug": "ink",           "name": "Charcoal",       "color": "#333F4B" },
        { "slug": "bg",            "name": "Background",     "color": "#ffffff" },
        { "slug": "bg-muted",      "name": "BG Muted",       "color": "#f3f6f9" },
        { "slug": "border",        "name": "Border",         "color": "#e3e8ee" },
        { "slug": "text",          "name": "Text",           "color": "#1c2632" },
        { "slug": "text-muted",    "name": "Text Muted",     "color": "#5a6776" },
        { "slug": "success",       "name": "Success",        "color": "#0f9d58" },
        { "slug": "warn",          "name": "Warn",           "color": "#d97706" },
        { "slug": "danger",        "name": "Danger",         "color": "#dc2626" },
        { "slug": "star",          "name": "Star",           "color": "#f5a623" }
      ],
      "gradients": [
        {
          "slug": "brand-fade",
          "name": "Brand fade",
          "gradient": "linear-gradient(135deg, #0A7AA9 0%, #1f4d68 60%, #333F4B 100%)"
        },
        {
          "slug": "brand-soft",
          "name": "Brand soft",
          "gradient": "linear-gradient(180deg, #e3f2f9 0%, #ffffff 100%)"
        }
      ],
      "custom": false,
      "customGradient": true,
      "defaultPalette": false,
      "defaultGradients": false
    },
    "typography": {
      "fluid": true,
      "fontFamilies": [
        {
          "slug": "montserrat",
          "name": "Montserrat",
          "fontFamily": "Montserrat, Inter, system-ui, -apple-system, Segoe UI, Roboto, sans-serif",
          "fontFace": [
            {
              "fontFamily": "Montserrat",
              "fontStyle": "normal",
              "fontWeight": "400 800",
              "src": ["https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap"]
            }
          ]
        }
      ],
      "fontSizes": [
        { "slug": "sm",  "name": "Small",   "size": "12px",  "fluid": false },
        { "slug": "md",  "name": "Medium",  "size": "14px",  "fluid": false },
        { "slug": "lg",  "name": "Large",   "size": "17px",  "fluid": { "min": "16px", "max": "18px" } },
        { "slug": "xl",  "name": "X Large", "size": "22px",  "fluid": { "min": "20px", "max": "26px" } },
        { "slug": "2xl", "name": "2X Large","size": "32px",  "fluid": { "min": "26px", "max": "36px" } },
        { "slug": "3xl", "name": "3X Large","size": "48px",  "fluid": { "min": "32px", "max": "56px" } }
      ]
    },
    "layout": {
      "contentSize": "1240px",
      "wideSize": "1440px"
    },
    "spacing": {
      "spacingScale": { "operator": "*", "increment": 1.5, "steps": 8, "mediumStep": 1.5, "unit": "rem" }
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--bg)",
      "text":       "var(--wp--preset--color--text)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--montserrat)",
      "lineHeight": "1.55"
    },
    "elements": {
      "h1": { "typography": { "fontWeight": "800", "letterSpacing": "-0.02em", "lineHeight": "1.1" } },
      "h2": { "typography": { "fontWeight": "700", "letterSpacing": "-0.02em" } },
      "h3": { "typography": { "fontWeight": "700", "letterSpacing": "-0.015em" } },
      "link": { "color": { "text": "var(--wp--preset--color--brand-deep)" } }
    }
  },
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ]
}
